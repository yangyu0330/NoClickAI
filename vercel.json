{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/server.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/server?__noclick_path=/health"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api/server?__noclick_path=/v1/:path*"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/downloads",
      "destination": "/downloads.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
