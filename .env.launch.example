# Copy this file to .env.launch.local and fill in real production values.
# .env.launch.local is ignored by Git. Do not commit real secrets.

STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NOCLICK_REQUIRE_SUBSCRIPTION=true

# Set these only after the external provider/store/signing work is complete.
NOCLICK_GOOGLE_OAUTH_VERIFIED=true
NOCLICK_GOOGLE_OAUTH_VERIFICATION_EVIDENCE=google-approved-YYYY-MM-DD

NOCLICK_ANDROID_RELEASE_SIGNED=true
NOCLICK_ANDROID_RELEASE_EVIDENCE=play-console-release-YYYY-MM-DD

NOCLICK_WINDOWS_CODE_SIGNED=true
NOCLICK_WINDOWS_CODE_SIGNING_EVIDENCE=authenticode-thumbprint-REPLACE
